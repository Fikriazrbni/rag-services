# =============================================================================
# RAG-as-a-Service Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=ragservice
DATABASE_URL=postgresql+asyncpg://rag:rag@db:5432/ragservice

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_REQUEST=20
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50
DEFAULT_TOP_K=5
SIMILARITY_THRESHOLD=0.3
CONTEXT_WINDOW_MESSAGES=10

# Encryption key for API keys at rest (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# LLM Provider Defaults (can also be configured via API at runtime)
# -----------------------------------------------------------------------------
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3
DEFAULT_EMBEDDING_PROVIDER=ollama
DEFAULT_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://host.docker.internal:11434
